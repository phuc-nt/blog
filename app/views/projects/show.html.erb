
<div id="post_show_content" class="skinny_wrapper wrapper_padding">
    <header>
        <p class="date"><%= @project.created_at.strftime("%A, %b %d")%></p>
        <h1><%= @project.title%></h1>
        <hr>
    </header>
    <div id="content">
        <%= markdown @project.description%>
    </div>
    <div class="button_wrapper">
        <a href="<%= @project.link%>" class="project_button" target="_blank">Visit <%= @project.title%></a>
    </div>
    <hr>
    <div id="share_box">
        <p>Share</p>
    
        <!-- <a onclick="javascript:window.open('http://www.facebook.com/sharer.php?<%= url_for([@project, {only_path: false}]) %>', '_blank', 'width=800, height=500, top=200, left=300');void(0);"><i class="fa fa-facebook"></i></a> -->

        <a href="http://www.facebook.com/sharer.php?u=<%= url_for([@project, {only_path: false}])%>" onclick="window.open(this.href, '_blank','left=50,top=50,width=600,height=350,toolbar=0'); return false;"><i class="fa fa-facebook"></i></a>

        <a href="http://twitter.com/share?text=<%= @project.title %> by@phuc-nt : &amp;url=<%= url_for([@project, {only_path: false}]) %>" onclick="window.open(this.href, '_blank','left=50,top=50,width=600,height=350,toolbar=0'); return false;"><i class="fa fa-twitter"></i></a>
    </div>

    <%= link_to "Sửa", edit_project_path(@project) %>
	<%= link_to "Delete", project_path(@project), method: :delete, data: { confirm: "Are you sure"} %>
    
    <hr>

</div>