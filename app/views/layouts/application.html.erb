<!DOCTYPE html>
<html>
<head>
	<meta charset="UTF-8">
    <title>phucnt's blog</title>
    <link href='https://fonts.googleapis.com/css?family=Raleway:400,700' rel='stylesheet' type='text/css'>
  <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track' => true %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track' => true %>
  <%= csrf_meta_tags %>
</head>
<body>
	<header id="main_navigation" class="clearfix">
        <%= link_to "phucnt", root_path,  class: "name" %>
        <nav>
            <%= link_to "Articles", posts_path %>
            <%= link_to "Projects", projects_path %>
            <a href="contact.html">Contact</a>
        </nav>
    </header>

    <% if notice %>
        <p class="notice"><%= notice %></p>
    <% elsif alert %>
        <p class="alert"><%= alert %></p>
    <% end %>
    
    <%= yield %>

    <footer id="main_footer">
        <p class="copyright">© 2016 phucnt</p>
        <nav id="link">
            <a href="https://www.facebook.com/phucnt176" target="_blank"><i class="fa fa-facebook"></i></a>
            <a href="https://github.com/phuc-nt" target="_blank"><i class="fa fa-github"></i></a>
            <a href="https://www.instagram.com/i.shoot.film" target="_blank"><i class="fa fa-instagram"></i></a>
        </nav>
    </footer>
</body>
</html>
