
<div id="post_show_content" class="skinny_wrapper wrapper_padding">
    <header>
        <p class="date"><%= @post.created_at.strftime("%A, %b %d")%></p>
        <h1><%= @post.title%></h1>
        <hr>
    </header>
    <div id="content">
        <%= markdown @post.content%>
    </div>

    <hr>
    <div id="share_box">
        <p>Share</p>
    
        <!-- <a onclick="javascript:window.open('http://www.facebook.com/sharer.php?<%= url_for([@post, {only_path: false}]) %>', '_blank', 'width=800, height=500, top=200, left=300');void(0);"><i class="fa fa-facebook"></i></a> -->

        <a href="http://www.facebook.com/sharer.php?u=<%= url_for([@post, {only_path: false}])%>" onclick="window.open(this.href, '_blank','left=50,top=50,width=600,height=350,toolbar=0'); return false;"><i class="fa fa-facebook"></i></a>

        <a href="http://twitter.com/share?text=<%= @post.title %> by@phuc-nt : &amp;url=<%= url_for([@post, {only_path: false}]) %>" onclick="window.open(this.href, '_blank','left=50,top=50,width=600,height=350,toolbar=0'); return false;"><i class="fa fa-twitter"></i></a>
    </div>

    <%= link_to "Edit", edit_post_path(@post) %>
	<%= link_to "Delete", post_path(@post), method: :delete, data: { comfirm: "Are you sure"} %>
    
    <hr>

    <%= render 'disqus' %>    
</div>